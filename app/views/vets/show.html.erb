<h1>Vets#show</h1>

<h1><%= "#{@vet.first_name} #{@vet.last_name}" %></h1>

<p><strong>Email:</strong> <%= @vet.email %></p>
<p><strong>Phone:</strong> <%= @vet.phone %></p>
<p><strong>Specialization:</strong> <%= @vet.specialization %></p>

<h2>Appointments</h2>
<ul>
  <% @vet.appointments.each do |appointment| %>
    <li><%= link_to appointment.reason, appointment_path(appointment) %></li>
  <% end %>
</ul>

<%= link_to "Back to Vets", vets_path %>